                                <img src="" alt="Selfie Preview" class="selfie-preview" id="selfiePreview" />
                                <span class="zone-icon">📷</span>
                                <span class="zone-title">Open Camera</span>
                                <span class="zone-hint">Complete liveness check</span>
                            </button>
                            <div id="selfieValidationMsg"></div>
                        </div>

                    </div>

                    <div class="optional-inputs">
                        <label class="optional-label">Optional: Enter NID info to verify</label>
                        <div class="input-row">
                            <input type="text" name="userName"   class="kyc-input" placeholder="Full name (English)" autocomplete="off" />
                            <input type="text" name="userNameBn" class="kyc-input bangla-input" placeholder="নাম (বাংলা)" autocomplete="off" />
                            <input type="text" name="userFather" class="kyc-input bangla-input" placeholder="পিতার নাম" autocomplete="off" />
                        </div>
                        <div class="input-row" style="margin-top:0.5rem;">
                            <input type="text" name="userMother" class="kyc-input bangla-input" placeholder="মাতার নাম" autocomplete="off" />
                            <input type="text" name="userNid"    class="kyc-input" placeholder="NID number" autocomplete="off" />
                            <input type="text" name="userDob"    class="kyc-input" placeholder="Date of birth (e.g. 01 Jan 1990)" autocomplete="off" />
                        </div>
                    </div>

                    <button type="submit" class="btn-verify" id="submitBtn">
                        <span id="btnText">🔍 Verify My Identity</span>
                        <div class="spinner" id="spinner"></div>
                    </button>
                </form>

                <hr class="divider" />

                <div class="security-row">
                    <div class="security-item"><span>🔒</span><span>Fully Offline</span></div>
                    <div class="security-item"><span>🤖</span><span>ArcFace AI</span></div>
                    <div class="security-item"><span>🗑️</span><span>Not Stored</span></div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="cameraModal">
        <div class="modal">
            <div class="modal-topbar">
                <div class="modal-brand">
                    <div class="modal-brand-icon">🛡️</div>
                    <div>
                        <div class="modal-brand-text">Liveness Verification</div>
                        <div class="modal-brand-sub">SecureBank · ArcFace AI</div>
                    </div>
                </div>
                <button class="modal-close" onclick="closeCamera()">✕</button>
            </div>

            <div class="liveness-header">
                <div class="liveness-title">Complete all 3 challenges to prove you are a live person</div>
                <div class="liveness-pills">
                    <div class="liveness-pill active" id="lsStep1">
                        <div class="pill-num" id="lsCircle1">1</div>
                        <div class="pill-info"><span class="pill-label">Blink</span><span class="pill-desc">3× auto</span></div>
                    </div>
                    <div class="liveness-pill" id="lsStep2">
                        <div class="pill-num" id="lsCircle2">2</div>
                        <div class="pill-info"><span class="pill-label">Head Turn</span><span class="pill-desc">L→R→L</span></div>
                    </div>
                    <div class="liveness-pill" id="lsStep3">
                        <div class="pill-num" id="lsCircle3">3</div>
                        <div class="pill-info"><span class="pill-label">Motion</span><span class="pill-desc">Live check</span></div>
                    </div>
                    <div class="liveness-pill" id="lsStep4">
                        <div class="pill-num" id="lsCircle4">📸</div>
                        <div class="pill-info"><span class="pill-label">Capture</span><span class="pill-desc">Auto</span></div>
                    </div>
                </div>
            </div>

            <div class="camera-wrap">
                <video id="cameraFeed" autoplay playsinline muted></video>
                <div class="face-guide"><div class="face-oval" id="faceOval"></div></div>
                <div class="challenge-card">
                    <div class="challenge-icon-wrap" id="challengeIconWrap">👁️</div>
                    <div class="challenge-body">
                        <div class="challenge-label" id="challengeLabel">Challenge 1 of 3</div>
                        <div class="challenge-instruction" id="challengeText">Camera starting...</div>
                        <div class="challenge-bar" id="challengeBar"></div>
                    </div>
                </div>
                <div class="flash" id="flashEffect"></div>
            </div>

            <canvas id="captureCanvas" style="display:none;"></canvas>

            <div id="blinkSection" style="display:none;padding:0.6rem 1.4rem 0.3rem;">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.4rem;">
                    <span style="font-size:0.72rem;color:var(--muted);">Blinks: <strong id="blinkCountLabel" style="color:var(--gold);">0 / 3</strong></span>
                    <div id="blinkDots" style="display:flex;gap:0.2rem;"></div>
                </div>
            </div>

            <div id="turnSection" style="display:none;padding:0.6rem 1.4rem 0.3rem;">
                <div style="display:flex;gap:0.4rem;margin-bottom:0.3rem;">
                    <div id="turnL" style="flex:1;padding:0.45rem;border-radius:8px;text-align:center;font-size:0.76rem;font-weight:700;background:rgba(255,255,255,0.03);border:1.5px solid rgba(255,255,255,0.1);color:var(--muted);transition:all 0.2s;">◀ LEFT</div>
                    <div id="turnC" style="flex:1;padding:0.45rem;border-radius:8px;text-align:center;font-size:0.76rem;font-weight:700;background:rgba(212,168,67,0.1);border:1.5px solid rgba(212,168,67,0.3);color:var(--gold);transition:all 0.2s;">● CENTRE</div>
                    <div id="turnR" style="flex:1;padding:0.45rem;border-radius:8px;text-align:center;font-size:0.76rem;font-weight:700;background:rgba(255,255,255,0.03);border:1.5px solid rgba(255,255,255,0.1);color:var(--muted);transition:all 0.2s;">RIGHT ▶</div>
                </div>
                <div id="turnSeqLabel" style="font-size:0.67rem;color:var(--muted);text-align:center;">Sequence: Right → Left → Right</div>
            </div>

            <div id="motionSection" style="display:none;padding:0.6rem 1.4rem 0.3rem;">
                <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:0.6rem 0.9rem;text-align:center;">
                    <div style="font-size:0.82rem;font-weight:600;color:var(--white);">🔍 Detecting live human motion…</div>
                    <div style="font-size:0.65rem;color:var(--muted);margin-top:0.2rem;">Breathe naturally — static photos &amp; screens are rejected</div>
                </div>
            </div>

            <div id="capturedSection" style="display:none;padding:0.6rem 1.4rem 0.8rem;">
                <div style="width:100%;padding:1.05rem;border-radius:13px;background:rgba(46,204,138,0.1);border:1.5px solid rgba(46,204,138,0.4);text-align:center;">
                    <div style="font-size:1.6rem;margin-bottom:0.3rem;">📸</div>
                    <div style="font-size:0.92rem;font-weight:700;color:var(--success);">Selfie captured automatically!</div>
                    <div style="font-size:0.68rem;color:var(--muted);margin-top:0.2rem;">Closing camera in a moment…</div>
                </div>
                <p style="text-align:center;font-size:0.68rem;color:var(--success);margin-top:0.5rem;font-weight:600;">✅ All 3 challenges verified — confirmed live human</p>
            </div>

            <div id="spoofSection" style="display:none;padding:0.6rem 1.4rem 0.8rem;">
                <div style="width:100%;padding:1.05rem;border-radius:13px;background:rgba(224,84,84,0.12);border:1.5px solid rgba(224,84,84,0.5);text-align:center;">
                    <div style="font-size:1.6rem;margin-bottom:0.3rem;">🚨</div>
                    <div style="font-size:0.92rem;font-weight:700;color:var(--danger);">Spoofing Attempt Detected</div>
                    <div style="font-size:0.72rem;color:rgba(224,84,84,0.8);margin-top:0.3rem;line-height:1.5;">Different faces were detected across the liveness stages.<br/>This may indicate an identity switch attempt.</div>
                </div>
                <p style="text-align:center;font-size:0.68rem;color:var(--danger);margin-top:0.5rem;font-weight:600;">⚠️ Verification failed — click Restart to try again</p>
            </div>

            <div class="modal-footer">
                <span class="modal-hint">Live · not stored · encrypted</span>
                <button type="button" id="retakeBtn" class="live-btn-retake" onclick="retakePhoto()">↺ Restart</button>
            </div>
        </div>
    </div>

    <footer class="footer">
        <span class="footer-text">© 2026 <span>SecureBank</span>. All rights reserved.</span>
        <span class="footer-text">Powered by <span>InsightFace ArcFace</span> · PaddleOCR (PP-OCRv4)</span>
    </footer>

    <script>

    let idCardValid   = false;
    let selfieReady   = false;
    let cameraStream  = null;

    const FRAME_MS = 120;

    let sessionId      = null;
    let frameTimer     = null;
    let challengeTimer = null;
    let sending        = false;
    let livePassed     = false;

    // ── Step progress helpers ──────────────────────────────────────
    function setStepDone(n, t) {
        const r = document.getElementById('step' + n + 'Row');
        const c = document.getElementById('step' + n + 'Circle');
        const d = document.getElementById('step' + n + 'Desc');
        if (r) r.className = 'step-row done';
        if (c) c.textContent = '✓';
        if (d && t) d.textContent = t;
    }
    function setStepActive(n, t) {
        const r = document.getElementById('step' + n + 'Row');
        const c = document.getElementById('step' + n + 'Circle');
        const d = document.getElementById('step' + n + 'Desc');
        if (r) r.className = 'step-row active';
        if (c) c.textContent = n;
        if (d && t) d.textContent = t;
    }
    function setStepInactive(n, t) {
        const r = document.getElementById('step' + n + 'Row');
        const c = document.getElementById('step' + n + 'Circle');
        const d = document.getElementById('step' + n + 'Desc');
        if (r) r.className = 'step-row inactive';
        if (c) c.textContent = n;
        if (d && t) d.textContent = t;
    }

    async function validateIdCard(input) {
        const file   = input.files[0];
        const zone   = document.getElementById('idZone');
        const msg    = document.getElementById('idValidationMsg');
        const nameEl = document.getElementById('idFileName');
        if (!file) return;
        if (!file.type.startsWith('image/')) {
            showIdError('Please upload an image file (JPEG or PNG).');
            input.value = '';
            return;
        }
        if (file.size > 15 * 1024 * 1024) {
            showIdError('File too large. Maximum 15MB allowed.');
            input.value = '';
            return;
        }

        idCardValid = false;
        zone.classList.remove('invalid', 'has-file');
        msg.innerHTML = '<div style="color:var(--gold);font-size:0.78rem;margin-top:0.3rem;">&#128269; Validating ID with PaddleOCR…</div>';

        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const fd    = new FormData();
            fd.append('idImage', file);
            fd.append('__RequestVerificationToken', token);

            const response = await fetch('/Verification/ValidateId', { method: 'POST', body: fd });
            const result   = await response.json();

            if (result.valid) {
                zone.classList.add('has-file');
                nameEl.textContent = '📄 ' + file.name;
                msg.innerHTML = '<div class="field-success">&#9989; ' + result.idType + ' detected &amp; verified</div>';
                idCardValid = true;
                setStepDone(1, result.idType + ' verified');
                if (!selfieReady) setStepActive(2, 'Open camera and complete liveness check');
                else              setStepActive(3, 'Click Verify to run ArcFace AI');
            } else {
                showIdError('&#10060; ' + (result.message || 'Not a valid Bangladesh ID.'));
                input.value = '';
                setStepActive(1, 'NID · Passport · Driving License');
            }
        } catch (e) {
            showIdError('&#10060; Cannot connect to server. Make sure Docker containers are running.');
            input.value = '';
        }
    }

    function showIdError(text) {
        document.getElementById('idValidationMsg').innerHTML = '<div class="field-error">' + text + '</div>';
        document.getElementById('idZone').classList.add('invalid');
        document.getElementById('idZone').classList.remove('has-file');
        idCardValid = false;
    }

    function validateForm() {
        let valid = true;

        if (!idCardValid) {
            document.getElementById('idValidationMsg').innerHTML =
                '<div class="field-error">Please upload and validate your ID card first.</div>';
            valid = false;
        }

        if (!selfieReady) {
            document.getElementById('selfieValidationMsg').innerHTML =
                '<div class="field-error">Please complete the liveness check first.</div>';
            valid = false;
        }

        const sid = document.getElementById('livenessSessionId').value;
        if (selfieReady && !sid) {
            document.getElementById('selfieValidationMsg').innerHTML =
                '<div class="field-error">Session expired. Please redo the liveness check.</div>';
            selfieReady = false;
            document.getElementById('selfieBtn').classList.remove('has-photo');
            valid = false;
        }

        if (valid) {
            const btn  = document.getElementById('submitBtn');
            const txt  = document.getElementById('btnText');
            const spin = document.getElementById('spinner');
            //btn.disabled       = true;
            txt.style.display  = 'none';
            spin.style.display = 'block';
            setStepActive(3, '⏳ ArcFace comparing faces…');
        }

        return valid;
    }

    function setLivenessStep(step) {
        ['lsStep1', 'lsStep2', 'lsStep3', 'lsStep4'].forEach((id, i) => {
            const el  = document.getElementById(id);
            const num = document.getElementById(id.replace('Step', 'Circle'));
            if (!el) return;
            if (step === -1) {
                // Spoof — mark all as failed
                el.className = 'liveness-pill spoof';
                if (num) num.textContent = '✕';
            } else if (i + 1 < step)  { el.className = 'liveness-pill done';   if (num) num.textContent = '✓'; }
            else if (i + 1 === step)   { el.className = 'liveness-pill active'; if (num) num.textContent = i + 1; }
            else                       { el.className = 'liveness-pill';        if (num) num.textContent = (i === 3 ? '📸' : i + 1); }
        });
    }

    function showChallenge(icon, text, label, success) {
        const w = document.getElementById('challengeIconWrap');
        const l = document.getElementById('challengeLabel');
        const t = document.getElementById('challengeText');
        if (!w) return;
        w.textContent = icon;
        w.className   = 'challenge-icon-wrap' + (success ? ' success' : '');
        t.textContent = text;
        if (label !== undefined) {
            l.textContent = label;
            l.className   = 'challenge-label' + (success ? ' success-label' : '');
        }
    }

    function setBar(pct) {
        const b = document.getElementById('challengeBar');
        if (b) b.style.width = Math.min(100, Math.max(0, pct || 0)) + '%';
    }

    function showSection(name) {
        ['blinkSection', 'turnSection', 'motionSection', 'capturedSection', 'spoofSection'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.style.display = 'none';
        });
        if (name && name !== 'none') {
            const el = document.getElementById(name + 'Section');
            if (el) el.style.display = 'block';
        }
    }

    function updateBlinkDots(count, needed) {
        const dots = document.getElementById('blinkDots');
        if (!dots) return;
        dots.innerHTML = '';
        for (let i = 0; i < needed; i++) {
            const d = document.createElement('span');
            d.textContent = i < count ? '●' : '○';
            d.style.cssText = 'font-size:1.3rem;margin:0 0.22rem;color:' +
                (i < count ? 'var(--success)' : 'var(--muted)') + ';transition:color 0.2s;';
            dots.appendChild(d);
        }
        const cnt = document.getElementById('blinkCountLabel');
        if (cnt) cnt.textContent = count + ' / ' + needed;
    }

    function updateTurnUI(sequence, currentDir, holdCount, holdNeeded) {
        const seqEl = document.getElementById('turnSeqLabel');
        if (seqEl) {
            const target = ['left', 'right', 'left'];
            const parts  = target.map((t, i) => {
                const done = sequence && i < sequence.length;
                return '<span style="color:' + (done ? 'var(--success)' : 'var(--muted)') + '">' +
                       (done ? '✓' : t.charAt(0).toUpperCase() + t.slice(1)) + '</span>';
            });
            seqEl.innerHTML = 'Sequence: ' + parts.join(' → ');
        }
        const boxL = document.getElementById('turnL');
        const boxC = document.getElementById('turnC');
        const boxR = document.getElementById('turnR');
        if (!boxL || !boxC || !boxR) return;

        const active  = 'background:rgba(212,168,67,0.20);border-color:var(--gold);color:var(--gold);';
        const done_s  = 'background:rgba(46,204,138,0.15);border-color:var(--success);color:var(--success);';
        const neutral = 'background:rgba(255,255,255,0.03);border-color:rgba(255,255,255,0.1);color:var(--muted);';
        const centre  = 'background:rgba(212,168,67,0.1);border-color:rgba(212,168,67,0.3);color:var(--gold);';

        boxL.style.cssText += neutral;
        boxC.style.cssText += centre;
        boxR.style.cssText += neutral;

        const dir = currentDir || 'center';
        const seq = sequence   || [];

        if (dir === 'left')  boxL.style.cssText += active;
        if (dir === 'right') boxR.style.cssText += active;
        if (seq.length >= 1) boxL.style.cssText += done_s;
        if (seq.length >= 2) boxR.style.cssText += done_s;
        if (seq.length >= 3) boxL.style.cssText += done_s;

        const pct  = (holdNeeded && holdCount) ? Math.min(holdCount / holdNeeded, 1.0) : 0;
        const bars = Math.round(pct * 5);
        const holdBar = bars > 0 ? ' [' + '█'.repeat(bars) + '░'.repeat(5 - bars) + ']' : '';

        if (dir === 'left'  && seq.length < 3) boxL.textContent = 'RIGHT ▶'  + holdBar;
        if (dir === 'right' && seq.length < 3) boxR.textContent = '◀ LEFT' + holdBar;
        if (dir === 'center')                  boxC.textContent = '● CENTRE';
    }

    function captureFrameBlob(video, canvas) {
        canvas.width  = 640;
        canvas.height = 480;
        const ctx = canvas.getContext('2d');
        // Draw unmirrored — do NOT ctx.scale(-1,1) here
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
        return new Promise(res => canvas.toBlob(res, 'image/jpeg', 0.92));
    }

    async function sendFrame() {
        if (sending || !sessionId || !cameraStream) return;
        const video  = document.getElementById('cameraFeed');
        const canvas = document.getElementById('captureCanvas');
        if (!video || video.paused || video.ended || video.videoWidth === 0) return;

        sending = true;
        try {
            const blob = await captureFrameBlob(video, canvas);
            const fd   = new FormData();
            fd.append('frame', blob, 'frame.jpg');

            const res = await fetch(
                '/Verification/LivenessFrame?sessionId=' + encodeURIComponent(sessionId),
                { method: 'POST', body: fd }
            );

            if (!res.ok) {
                if (res.status === 404) {
                    stopFrameSending();
                    showChallenge('⚠️', 'Session expired. Restart.', 'Error', false);
                }
                return;
            }

            handleResponse(await res.json());
        } catch (e) {
            showChallenge('⚠️', 'Server error — retrying…', 'Error', false);
        } finally {
            sending = false;
        }
    }

    function handleResponse(data) {
        const { stage, passed, progress, icon, message,
                blink_count, blink_needed, turn_sequence,
                challenge_done, auto_captured } = data;

        setBar(progress);
        showChallenge(icon || '👁️', message || '', undefined, passed || stage === 'done');

        if (stage === 'align') {
            document.getElementById('faceOval').classList.remove('aligned');
            showSection('none');
            return;
        }

        if (stage === 'blink') {
            document.getElementById('faceOval').classList.add('aligned');
            setLivenessStep(1);
            showSection('blink');
            updateBlinkDots(blink_count || 0, blink_needed || 3);
            return;
        }

        if (stage === 'turn') {
            setLivenessStep(2);
            showSection('turn');
            updateTurnUI(turn_sequence, data.current_direction, data.hold_count, data.hold_needed);
            return;
        }

        if (stage === 'motion') {
            setLivenessStep(3);
            showSection('motion');
            return;
        }

        if (stage === 'spoof' || data.spoof_flagged) {
            if (challengeTimer) { clearTimeout(challengeTimer); challengeTimer = null; }
            stopFrameSending();
            livePassed  = false;
            selfieReady = false;

            // Clear any partial session
            const hf = document.getElementById('livenessSessionId');
            if (hf) hf.value = '';

            try {
                const flash = document.getElementById('flashEffect');
                if (flash) {
                    flash.style.background = 'rgba(224,84,84,0.6)';
                    flash.style.opacity = '1';
                    setTimeout(() => {
                        flash.style.opacity = '0';
                        flash.style.background = 'white';
                    }, 600);
                }
            } catch (e) { /* non-critical */ }

            showSection('spoof');
            showChallenge('🚨', data.message || '⚠️ Identity spoofing detected — different faces present during liveness check', 'Security Alert', false);
            setLivenessStep(-1);  

            document.getElementById('retakeBtn').classList.add('visible');
            document.getElementById('selfieValidationMsg').innerHTML =
                '<div class="field-error">🚨 Spoofing detected: different faces during liveness. Please restart.</div>';
            setStepActive(2, '⚠️ Liveness check failed — restart required');

            console.warn('[SECURITY] Spoof detected:', data.consistency_scores || data.failures);
            return;
        }

        if (stage === 'done' || passed) {
            if (challengeTimer) { clearTimeout(challengeTimer); challengeTimer = null; }

            const hf = document.getElementById('livenessSessionId');
            if (hf && sessionId) {
                hf.value = sessionId;
                console.log('[LIVENESS] sessionId set:', sessionId);
            }

            livePassed = true;
            stopFrameSending();

            try {
                const flash = document.getElementById('flashEffect');
                if (flash) { flash.style.opacity = '1'; setTimeout(() => { flash.style.opacity = '0'; }, 250); }
            } catch (e) { /* non-critical */ }

            setLivenessStep(4);
            showSection('captured');

            try {
                const v    = document.getElementById('cameraFeed');
                const snap = document.createElement('canvas');
                snap.width  = v.videoWidth  || 320;
                snap.height = v.videoHeight || 240;
                const sc = snap.getContext('2d');
                sc.translate(snap.width, 0);
                sc.scale(-1, 1);            
                sc.drawImage(v, 0, 0);
                const preview = document.getElementById('selfiePreview');
                if (preview) preview.src = snap.toDataURL('image/jpeg', 0.9);
            } catch (e) {
                console.warn('[LIVENESS] selfie preview failed (non-critical):', e.message);
            }

            document.getElementById('selfieBtn').classList.add('has-photo');
            document.getElementById('selfieValidationMsg').innerHTML =
                '<div class="field-success">&#9989; Selfie auto-captured during liveness check</div>';
            selfieReady = true;

            setStepDone(2, 'Liveness verified');
            if (idCardValid) setStepActive(3, 'Click Verify to run ArcFace AI');
            else             setStepInactive(3, 'Upload ID card first');

            document.getElementById('retakeBtn').classList.add('visible');

            setTimeout(() => {
                stopCamera();
                document.getElementById('cameraModal').classList.remove('open');
            }, 1800);

            return;
        }

        if (challenge_done === 'align') {
            challengeTimer = setTimeout(() => { showSection('blink'); setLivenessStep(1); }, 600);
        } else if (challenge_done === 'blink') {
            challengeTimer = setTimeout(() => { showSection('turn');  setLivenessStep(2); }, 1200);
        } else if (challenge_done === 'turn') {
            challengeTimer = setTimeout(() => { showSection('motion'); setLivenessStep(3); }, 1200);
        }
    }

    function startFrameSending() { stopFrameSending(); frameTimer = setInterval(sendFrame, FRAME_MS); }
    function stopFrameSending()  { if (frameTimer) { clearInterval(frameTimer); frameTimer = null; } }


    async function openCamera() {
        document.getElementById('cameraModal').classList.add('open');
        livePassed = false; sessionId = null; sending = false;
        setLivenessStep(1);
        showSection('none');
        showChallenge('⏳', 'Starting camera…', 'Please wait', false);
        setBar(0);
        document.getElementById('faceOval').classList.remove('aligned');
        document.getElementById('retakeBtn').classList.remove('visible');

        try {
            cameraStream = await navigator.mediaDevices.getUserMedia({
                video: { facingMode: 'user', width: { ideal: 1280 }, height: { ideal: 720 } },
                audio: false,
            });
            const video = document.getElementById('cameraFeed');
            video.srcObject = cameraStream;
            await video.play();

            const res = await fetch('/Verification/LivenessStart', { method: 'POST' });
            if (!res.ok) throw new Error('Python API unavailable (status ' + res.status + ')');

            const data = await res.json();
            sessionId  = data.session_id;
            console.log('[LIVENESS] Session created:', sessionId);

            showSection('none');
            showChallenge('👤', 'Position your face in the oval and hold still', 'Face Alignment', false);
            startFrameSending();
        } catch (err) {
            console.error('[LIVENESS] openCamera error:', err);
            if (err.name === 'NotAllowedError')
                showChallenge('❌', 'Camera access denied. Please allow camera access and retry.', 'Error', false);
            else
                showChallenge('❌', 'Cannot connect. Make sure Docker containers are running. ' + err.message, 'Connection Error', false);
        }
    }

    function closeCamera() {
        if (sessionId) {
            fetch('/Verification/LivenessCancel?sessionId=' + encodeURIComponent(sessionId), { method: 'POST' })
                .catch(() => {});
        }
        stopCamera();
        document.getElementById('cameraModal').classList.remove('open');
    }

    function stopCamera() {
        stopFrameSending();
        if (challengeTimer) { clearTimeout(challengeTimer); challengeTimer = null; }
        if (cameraStream) { cameraStream.getTracks().forEach(t => t.stop()); cameraStream = null; }
    }

    function retakePhoto() {
        stopCamera();
        livePassed  = false;
        selfieReady = false;
        sessionId   = null;

        const hf = document.getElementById('livenessSessionId');
        if (hf) hf.value = '';

        document.getElementById('selfieBtn').classList.remove('has-photo');
        const preview = document.getElementById('selfiePreview');
        if (preview) preview.src = '';
        document.getElementById('selfieValidationMsg').innerHTML = '';

        setStepActive(2, 'Retake liveness check');
        setStepInactive(3, 'Waiting for selfie…');
        openCamera();
    }

    document.getElementById("verifyForm").addEventListener("submit", function (e) {
    if (!validateForm()) {
        e.preventDefault();
        return;
    }

    setTimeout(() => {
        const btn  = document.getElementById('submitBtn');
        const txt  = document.getElementById('btnText');
        const spin = document.getElementById('spinner');

        btn.disabled = true;
        txt.style.display = 'none';
        spin.style.display = 'block';
    }, 0);
});
    </script>
</body>
</html>