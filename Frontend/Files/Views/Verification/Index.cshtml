@{
    ViewData["Title"] = "Face Verification";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SecureBank — Identity Verification</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }


        :root {
            --navy:       #0b1629;
            --navy-mid:   #112240;
            --navy-light: #1a3560;
            --gold:       #d4a843;
            --gold-light: #e8c37a;
            --gold-dim:   #8a6b25;
            --cream:      #f5f0e8;
            --white:      #ffffff;
            --muted:      #8899aa;
            --danger:     #e05454;
            --success:    #2ecc8a;
            --border:     rgba(212,168,67,0.18);
            --radius:     14px;
        }

        body {
            background: var(--navy); color: var(--cream);
            font-family: -apple-system,'Segoe UI',system-ui,sans-serif;
            min-height: 100vh; display: flex; flex-direction: column;
        }

        .navbar {
            display: flex; align-items: center; justify-content: space-between;
            padding: 1.2rem 3rem; border-bottom: 1px solid var(--border);
            background: rgba(11,22,41,0.97); backdrop-filter: blur(12px);
            position: sticky; top: 0; z-index: 100;
        }
        .nav-logo { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
        .logo-emblem {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, var(--gold), var(--gold-dim));
            border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem;
        }
        .logo-text { font-family: Georgia,'Times New Roman',serif; font-size: 1.25rem; color: var(--white); }
        .logo-text span { color: var(--gold); }
        .nav-badge {
            font-size: 0.72rem; font-weight: 600;
            background: rgba(212,168,67,0.12); color: var(--gold);
            border: 1px solid var(--border); padding: 0.3rem 0.8rem;
            border-radius: 999px; letter-spacing: 0.06em; text-transform: uppercase;
        }

        .page-body { flex: 1; display: grid; grid-template-columns: 1fr 1fr; min-height: calc(100vh - 67px); }

        .left-col {
            background: radial-gradient(ellipse 80% 70% at 20% 30%, rgba(212,168,67,0.09) 0%, transparent 60%), linear-gradient(160deg, var(--navy) 0%, var(--navy-mid) 100%);
            padding: 4rem 3.5rem;
            display: flex; flex-direction: column; justify-content: center;
            position: relative; border-right: 1px solid var(--border);
        }
        .hero-tag {
            display: inline-flex; align-items: center; gap: 0.5rem;
            font-size: 0.72rem; font-weight: 600; color: var(--gold);
            text-transform: uppercase; letter-spacing: 0.1em;
            background: rgba(212,168,67,0.1); border: 1px solid var(--border);
            padding: 0.4rem 1rem; border-radius: 999px;
            margin-bottom: 2rem; width: fit-content;
        }
        .hero-tag::before {
            content: ''; width: 6px; height: 6px;
            background: var(--gold); border-radius: 50%; animation: pulse 2s infinite;
        }
        @@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.7)} }
        .hero-title {
            font-family: Georgia,'Times New Roman',serif;
            font-size: clamp(2.2rem, 3.5vw, 3.2rem);
            font-weight: 700; color: var(--white);
            line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 1.2rem;
        }
        .hero-title span { color: var(--gold); }
        .hero-subtitle { font-size: 0.95rem; color: var(--muted); line-height: 1.8; margin-bottom: 2.8rem; max-width: 380px; }

        .steps { display: flex; flex-direction: column; gap: 0; margin-bottom: 3rem; }
        .step-row { display: flex; align-items: flex-start; gap: 1rem; position: relative; }
        .step-row:not(:last-child)::before {
            content: ''; position: absolute; left: 19px; top: 40px;
            width: 2px; height: calc(100% - 8px); background: var(--border);
        }
        .step-left { display: flex; flex-direction: column; align-items: center; padding-bottom: 1.4rem; }
        .step-circle {
            width: 40px; height: 40px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.85rem; font-weight: 700; flex-shrink: 0; z-index: 1;
        }
        .step-row.active .step-circle   { background: var(--gold); color: var(--navy); box-shadow: 0 0 0 4px rgba(212,168,67,0.2); }
        .step-row.inactive .step-circle { background: var(--navy-light); color: var(--muted); border: 1px solid var(--border); }
        .step-row.done .step-circle     { background: var(--gold); color: var(--navy); }
        .step-info { display: flex; flex-direction: column; gap: 0.15rem; padding-top: 0.6rem; padding-bottom: 1.4rem; }
        .step-name { font-size: 0.88rem; font-weight: 600; }
        .step-row.active .step-name   { color: var(--white); }
        .step-row.inactive .step-name { color: var(--muted); }
        .step-row.done .step-name     { color: var(--gold); }
        .step-desc { font-size: 0.75rem; color: var(--muted); }
        .step-row.done .step-desc     { color: rgba(212,168,67,0.7); }
        .step-row.done::before        { background: var(--gold); opacity: 0.5; }

        .features { display: flex; flex-wrap: wrap; gap: 0.6rem; }
        .feature-badge {
            display: flex; align-items: center; gap: 0.4rem;
            font-size: 0.73rem; font-weight: 500; padding: 0.4rem 0.9rem;
            border-radius: 999px; background: rgba(212,168,67,0.07);
            color: var(--gold-light); border: 1px solid rgba(212,168,67,0.15);
        }

        .right-col { background: var(--navy-mid); padding: 4rem 3rem; display: flex; flex-direction: column; justify-content: center; }

        .card {
            background: var(--navy); border: 1px solid var(--border);
            border-radius: 24px; padding: 2.2rem;
            box-shadow: 0 24px 60px rgba(0,0,0,0.4);
        }
        .card-header {
            display: flex; align-items: center; gap: 1rem;
            margin-bottom: 1.8rem; padding-bottom: 1.4rem;
            border-bottom: 1px solid var(--border);
        }
        .card-icon {
            width: 46px; height: 46px;
            background: linear-gradient(135deg, rgba(212,168,67,0.2), rgba(212,168,67,0.04));
            border: 1px solid var(--border); border-radius: 12px;
            display: flex; align-items: center; justify-content: center; font-size: 1.3rem;
        }
        .card-header-text h2 { font-size: 1rem; font-weight: 600; color: var(--white); margin-bottom: 0.15rem; }
        .card-header-text p  { font-size: 0.75rem; color: var(--muted); }

        .upload-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.4rem; }
        .upload-group label.upload-label {
            font-size: 0.72rem; font-weight: 600; color: var(--gold);
            text-transform: uppercase; letter-spacing: 0.08em;
            display: block; margin-bottom: 0.4rem;
        }

        .upload-zone {
            border: 1.5px dashed rgba(212,168,67,0.3); border-radius: var(--radius);
            padding: 1.6rem 0.8rem; text-align: center; cursor: pointer;
            transition: all 0.2s ease; position: relative; overflow: hidden;
            background: rgba(255,255,255,0.02);
        }
        .upload-zone:hover     { border-color: var(--gold); background: rgba(212,168,67,0.04); }
        .upload-zone.has-file  { border-color: var(--gold); border-style: solid; background: rgba(212,168,67,0.06); }
        .upload-zone.invalid   { border-color: var(--danger); border-style: solid; background: rgba(224,84,84,0.06); }
        .upload-zone input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
        .zone-icon     { font-size: 1.8rem; display: block; margin-bottom: 0.5rem; }
        .zone-title    { font-size: 0.8rem; font-weight: 500; color: var(--cream); display: block; margin-bottom: 0.25rem; }
        .zone-hint     { font-size: 0.68rem; color: var(--muted); }
        .zone-filename { font-family: Consolas,monospace; font-size: 0.65rem; color: var(--gold-light); margin-top: 0.4rem; word-break: break-all; display: none; }
        .upload-zone.has-file .zone-filename { display: block; }

        .selfie-btn {
            border: 1.5px dashed rgba(212,168,67,0.3); border-radius: var(--radius);
            padding: 1.6rem 0.8rem; text-align: center; cursor: pointer;
            transition: all 0.2s ease; background: rgba(255,255,255,0.02); width: 100%;
        }
        .selfie-btn:hover    { border-color: var(--gold); background: rgba(212,168,67,0.04); }
        .selfie-btn.has-photo { border-color: var(--gold); border-style: solid; background: rgba(212,168,67,0.06); }
        .selfie-preview { width: 70px; height: 70px; border-radius: 50%; object-fit: cover; border: 2px solid var(--gold); margin: 0 auto 0.5rem; display: none; }
        .selfie-btn.has-photo .selfie-preview { display: block; }
        .selfie-btn.has-photo .zone-icon { display: none; }

        .field-error   { color: var(--danger);  font-size: 0.72rem; margin-top: 0.3rem; }
        .field-success { color: var(--success); font-size: 0.72rem; margin-top: 0.3rem; }

        .optional-inputs { margin-bottom: 1.2rem; }
        .optional-label {
            font-size: 0.7rem; font-weight: 600; color: var(--muted);
            text-transform: uppercase; letter-spacing: 0.08em;
            display: block; margin-bottom: 0.6rem;
        }
        .input-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.6rem; }
        .kyc-input {
            background: rgba(255,255,255,0.03); border: 1px solid var(--border);
            border-radius: 8px; padding: 0.55rem 0.8rem;
            color: var(--cream); font-size: 0.82rem; width: 100%;
            outline: none; transition: border-color 0.2s;
        }
        .kyc-input::placeholder { color: var(--muted); }
        .kyc-input:focus { border-color: var(--gold); }

        .bangla-input {
            font-family: 'Shonar Bangla', 'Vrinda', 'Siyam Rupali', 'Kalpurush',
                         'Likhan', 'Mukti', 'Akaash', 'Lohit Bengali',
                         'Nirmala UI', serif;
            font-size: 0.9rem;
        }

        .btn-verify {
            width: 100%; padding: 1rem;
            background: linear-gradient(135deg, var(--gold), var(--gold-dim));
            color: var(--navy); font-size: 0.95rem; font-weight: 700;
            border: none; border-radius: var(--radius); cursor: pointer;
            transition: all 0.2s ease;
            display: flex; align-items: center; justify-content: center; gap: 0.5rem;
        }
        .btn-verify:hover    { opacity: 0.92; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(212,168,67,0.25); }
        .btn-verify:active   { transform: translateY(0); }
        .btn-verify:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
        .spinner { display: none; width: 18px; height: 18px; border: 2px solid rgba(11,22,41,0.3); border-top-color: var(--navy); border-radius: 50%; animation: spin 0.7s linear infinite; }
        @@keyframes spin { to { transform: rotate(360deg); } }

        .divider { border: none; border-top: 1px solid var(--border); margin: 1.4rem 0 1.2rem; }
        .security-row { display: flex; align-items: center; justify-content: center; gap: 1.2rem; flex-wrap: wrap; }
        .security-item { display: flex; align-items: center; gap: 0.35rem; font-size: 0.7rem; color: var(--muted); }

        .modal-overlay { position:fixed; inset:0; z-index:1000; background:rgba(0,0,0,0.88); backdrop-filter:blur(8px); display:none; align-items:center; justify-content:center; padding:1rem; }
        .modal-overlay.open { display:flex; }
        .modal { background:var(--navy-mid); border:1px solid rgba(212,168,67,0.2); border-radius:26px; width:100%; max-width:520px; box-shadow:0 40px 100px rgba(0,0,0,0.8); overflow:hidden; animation:fadeUp 0.3s ease both; }
        @@keyframes fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
        .modal-topbar { display:flex; align-items:center; justify-content:space-between; padding:1.1rem 1.4rem 0; }
        .modal-brand { display:flex; align-items:center; gap:0.6rem; }
        .modal-brand-icon { width:32px; height:32px; border-radius:8px; background:rgba(212,168,67,0.15); border:1px solid var(--border); display:flex; align-items:center; justify-content:center; font-size:0.95rem; }
        .modal-brand-text { font-size:0.8rem; font-weight:600; color:var(--white); }
        .modal-brand-sub  { font-size:0.65rem; color:var(--muted); }
        .modal-close { width:32px; height:32px; border-radius:50%; background:rgba(255,255,255,0.06); border:1px solid var(--border); color:var(--muted); cursor:pointer; font-size:0.9rem; display:flex; align-items:center; justify-content:center; transition:all 0.2s; }
        .modal-close:hover { background:rgba(224,84,84,0.15); color:var(--danger); border-color:rgba(224,84,84,0.4); }

        .liveness-header { padding:0.9rem 1.4rem 0.7rem; border-bottom:1px solid rgba(212,168,67,0.1); }
        .liveness-title { font-size:0.68rem; text-transform:uppercase; letter-spacing:0.08em; color:var(--muted); margin-bottom:0.65rem; }
        .liveness-pills { display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:0.35rem; }
        .liveness-pill { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.07); border-radius:9px; padding:0.45rem 0.55rem; display:flex; align-items:center; gap:0.4rem; transition:all 0.35s; }
        .pill-num { width:20px; height:20px; border-radius:50%; flex-shrink:0; background:rgba(255,255,255,0.06); border:1.5px solid rgba(255,255,255,0.12); display:flex; align-items:center; justify-content:center; font-size:0.62rem; font-weight:700; color:var(--muted); transition:all 0.35s; }
        .pill-info { min-width:0; }
        .pill-label { font-size:0.66rem; font-weight:600; color:var(--muted); display:block; }
        .pill-desc  { font-size:0.56rem; color:rgba(255,255,255,0.22); display:block; }
        .liveness-pill.active { background:rgba(212,168,67,0.08); border-color:rgba(212,168,67,0.3); }
        .liveness-pill.active .pill-num   { background:rgba(212,168,67,0.15); border-color:var(--gold); color:var(--gold); }
        .liveness-pill.active .pill-label { color:var(--gold); }
        .liveness-pill.done { background:rgba(46,204,138,0.07); border-color:rgba(46,204,138,0.3); }
        .liveness-pill.done .pill-num     { background:var(--success); border-color:var(--success); color:#fff; }
        .liveness-pill.done .pill-label   { color:var(--success); }
        .liveness-pill.spoof { background:rgba(224,84,84,0.1); border-color:rgba(224,84,84,0.4); }
        .liveness-pill.spoof .pill-num   { background:var(--danger); border-color:var(--danger); color:#fff; }
        .liveness-pill.spoof .pill-label { color:var(--danger); }

        .camera-wrap { position:relative; background:#000; aspect-ratio:4/3; overflow:hidden; }
        #cameraFeed { width:100%; height:100%; object-fit:cover; display:block; transform:scaleX(-1); }
        .camera-wrap::after { content:''; position:absolute; inset:0; pointer-events:none; background:radial-gradient(ellipse 65% 65% at 50% 50%,transparent 45%,rgba(0,0,0,0.5) 100%); }
        .face-guide { position:absolute; inset:0; z-index:2; display:flex; align-items:center; justify-content:center; pointer-events:none; }
        .face-oval { width:190px; height:245px; border:2.5px solid rgba(212,168,67,0.65); border-radius:50%; box-shadow:0 0 0 9999px rgba(0,0,0,0.42); transition:all 0.3s; position:relative; }
        .face-oval.aligned { border-color:var(--success); box-shadow:0 0 0 9999px rgba(0,0,0,0.38),0 0 28px rgba(46,204,138,0.55); animation:ovalPulse 2s ease-in-out infinite; }
        .face-oval::before { content:''; position:absolute; top:-3px; left:-3px; width:18px; height:18px; border-top:3px solid var(--gold); border-left:3px solid var(--gold); border-radius:4px 0 0 0; }
        .face-oval::after  { content:''; position:absolute; bottom:-3px; right:-3px; width:18px; height:18px; border-bottom:3px solid var(--gold); border-right:3px solid var(--gold); border-radius:0 0 4px 0; }
        @@keyframes ovalPulse { 0%,100%{box-shadow:0 0 0 9999px rgba(0,0,0,0.38),0 0 16px rgba(46,204,138,0.4)}50%{box-shadow:0 0 0 9999px rgba(0,0,0,0.38),0 0 34px rgba(46,204,138,0.72)} }
        .challenge-card { position:absolute; bottom:0; left:0; right:0; z-index:3; padding:0.8rem 0.9rem; background:linear-gradient(to top,rgba(7,14,27,0.97),rgba(7,14,27,0.6) 70%,transparent); display:flex; align-items:center; gap:0.7rem; }
        .challenge-icon-wrap { width:40px; height:40px; border-radius:11px; flex-shrink:0; background:rgba(212,168,67,0.12); border:1px solid rgba(212,168,67,0.25); display:flex; align-items:center; justify-content:center; font-size:1.2rem; transition:all 0.3s; }
        .challenge-icon-wrap.success { background:rgba(46,204,138,0.12); border-color:rgba(46,204,138,0.3); }
        .challenge-body { flex:1; min-width:0; position:relative; }
        .challenge-label { font-size:0.62rem; text-transform:uppercase; letter-spacing:0.07em; color:var(--gold); font-weight:600; margin-bottom:0.12rem; }
        .challenge-label.success-label { color:var(--success); }
        .challenge-instruction { font-size:0.82rem; font-weight:600; color:var(--white); }
        .challenge-bar { position:absolute; bottom:0; left:0; height:2px; background:linear-gradient(90deg,var(--gold),var(--gold-light)); width:0%; transition:width 0.18s linear; border-radius:1px; }
        .flash { position:absolute; inset:0; z-index:10; background:white; opacity:0; pointer-events:none; transition:opacity 0.06s; }

        .modal-footer { padding:0.8rem 1.4rem; display:flex; align-items:center; justify-content:space-between; border-top:1px solid rgba(255,255,255,0.05); }
        .modal-hint { font-size:0.68rem; color:var(--muted); }
        .modal-hint::before { content:'🔒'; margin-right:0.3rem; }
        .live-btn-retake { padding:0.45rem 0.9rem; background:rgba(255,255,255,0.05); color:var(--muted); border:1px solid rgba(255,255,255,0.1); border-radius:7px; font-size:0.75rem; font-weight:600; cursor:pointer; transition:all 0.2s; display:none; }
        .live-btn-retake.visible { display:block; }
        .live-btn-retake:hover { background:rgba(255,255,255,0.1); color:var(--cream); }

        .id-notice { background:rgba(212,168,67,0.07); border:1px solid rgba(212,168,67,0.2); border-radius:var(--radius); padding:0.7rem 0.9rem; font-size:0.75rem; color:var(--gold-light); margin-bottom:1rem; display:flex; align-items:flex-start; gap:0.5rem; }

        .footer { background:var(--navy); border-top:1px solid var(--border); padding:1rem 3rem; display:flex; align-items:center; justify-content:space-between; }
        .footer-text { font-size:0.73rem; color:var(--muted); }
        .footer-text span { color:var(--gold); }

        @@media (max-width: 1024px) {
            .page-body { grid-template-columns: 1fr; }
            .left-col  { padding: 2.5rem 2rem; border-right: none; border-bottom: 1px solid var(--border); }
            .right-col { padding: 2.5rem 1.5rem; }
            .navbar    { padding: 1rem 1.5rem; }
            .input-row { grid-template-columns: 1fr; }
            .footer    { flex-direction: column; gap: 0.4rem; text-align: center; }
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <a class="nav-logo" href="#">
            <div class="logo-emblem">🏦</div>
            <span class="logo-text">Secure<span>Bank</span></span>
        </a>
        <span class="nav-badge">🔒 Secure Session</span>
    </nav>

    <div class="page-body">
        <div class="left-col">
            <div class="hero-tag">AI-Powered Identity Verification</div>
            <h1 class="hero-title">Verify Your<br /><span>Identity</span></h1>
            <p class="hero-subtitle">
                Upload your NID card and complete the liveness check.
                Our ArcFace AI will confirm your identity instantly and securely — fully offline.
            </p>
            <div class="steps">
                <div class="step-row active" id="step1Row">
                    <div class="step-left"><div class="step-circle" id="step1Circle">1</div></div>
                    <div class="step-info">
                        <span class="step-name">Upload ID Card</span>
                        <span class="step-desc" id="step1Desc">NID · Passport · Driving License</span>
                    </div>
                </div>
                <div class="step-row inactive" id="step2Row">
                    <div class="step-left"><div class="step-circle" id="step2Circle">2</div></div>
                    <div class="step-info">
                        <span class="step-name">Liveness Check</span>
                        <span class="step-desc" id="step2Desc">Blink · Head turn · Motion</span>
                    </div>
                </div>
                <div class="step-row inactive" id="step3Row">
                    <div class="step-left"><div class="step-circle" id="step3Circle">3</div></div>
                    <div class="step-info">
                        <span class="step-name">AI Verification</span>
                        <span class="step-desc" id="step3Desc">ArcFace face matching result</span>
                    </div>
                </div>
            </div>
            <div class="features">
                <span class="feature-badge">🔐 Login Auth</span>
                <span class="feature-badge">📋 KYC</span>
                <span class="feature-badge">🏦 Account Opening</span>
                <span class="feature-badge">💳 Transaction Approval</span>
            </div>
        </div>

        <div class="right-col">
            <div class="card">
                <div class="card-header">
                    <div class="card-icon">🪪</div>
                    <div class="card-header-text">
                        <h2>Identity Document &amp; Live Selfie</h2>
                        <p>Both required · ID card must be a physical document photo</p>
                    </div>
                </div>

                <div class="id-notice">
                    ℹ️ <span>Only Bangladeshi NID accepted. Random photos will be rejected.</span>
                </div>

                <form asp-controller="Verification" asp-action="Verify"
                      method="post" enctype="multipart/form-data" id="verifyForm">

                    @Html.AntiForgeryToken()
                    <input type="hidden" name="sessionId" id="livenessSessionId" />

                    <div class="upload-grid">
                        <div class="upload-group">
                            <label class="upload-label">🪪 ID Card Photo</label>
                            <div class="upload-zone" id="idZone">
                                <input type="file" name="idImage" id="idImageInput"
                                       accept="image/*"
                                       onchange="validateIdCard(this)" />
                                <span class="zone-icon">🪪</span>
                                <span class="zone-title">Upload ID Card</span>
                                <span class="zone-hint">JPEG / PNG, max 15MB</span>
